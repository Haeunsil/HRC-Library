<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>HRC Library</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>
<a href="#main" class="skip">본문으로 건너뛰기</a>

<header>
  <div class="container topbar">
    <div class="logo">📚 라이브러리</div>
    <div class="search-inline">
      <input id="q" type="text" placeholder="키워드 입력 (자동 포함 검색)" aria-describedby="q-help" />
    </div>
  </div>
  <div class="container controls" role="region" aria-label="공통 컨트롤">
    <div class="filter-row">
                    <div class="filter-item">
          <select id="cat1">
            <option value="">단수/복수</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat2">
            <option value="">순위</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat3">
            <option value="">단일척도</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat4">
            <option value="">척도</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat5">
            <option value="">오픈</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat6">
            <option value="">이미지</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat7">
            <option value="">동영상</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat8">
            <option value="">응답자정보</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat9">
            <option value="">가격입력</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat10">
            <option value="">합계</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat11">
            <option value="">기타</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
            <option value="3">3번</option>
            <option value="4">4번</option>
            <option value="5">5번</option>
          </select>
        </div>
        <div class="filter-item">
          <select id="cat12">
            <option value="">커스텀</option>
            <option value="1">1번</option>
            <option value="2">2번</option>
