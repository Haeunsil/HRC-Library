        </div>
         </div>
   </div>
   
                                               <!-- 선택된 값 표시 영역 -->
       <div class="container">
         <div class="selection-display">
           <div class="selection-item">
             <span class="selected-value">선택된 항목이 없습니다</span>
           </div>
         </div>
       </div>
 </header>

<main id="main" class="container" tabindex="-1">
  <!-- 왼쪽: 뷰 -->
  <section class="panel" aria-labelledby="view-title">
    <div class="panel-title" id="view-title">뷰</div>
    <div class="view-modes" role="group" aria-label="뷰 옵션">
      <button class="chip" data-mode="pc" aria-pressed="true">PC</button>
      <button class="chip" data-mode="mobile">모바일</button>
      <button class="chip" data-mode="mobile-land">모바일(가로)</button>
    </div>
    <div class="panel-body">
	<div class="loadbar" aria-label="미리보기 URL 로더">
	  <input id="previewUrl" type="url" placeholder="https:// 미리보기할 페이지 URL" />
	  <button id="loadBtn" class="btn primary">불러오기</button>
	</div>
	<div class="iframe-wrap">
	  <iframe id="preview" class="device" title="컴포넌트 미리보기"></iframe>
	</div>
	
	<script>
	  const input  = document.getElementById("previewUrl");
	  const button = document.getElementById("loadBtn");
	  const iframe = document.getElementById("preview");
	
	  function normalizeUrl(value) {
	    let v = value.trim();
	    if (!v) return "";
	    // 프로토콜이 없으면 https:// 붙이기
	    if (!/^https?:\/\//i.test(v)) {
	      v = "https://" + v;
	    }
	    return v;
	  }
	
	  function loadPreview() {
	    const url = normalizeUrl(input.value);
	    if (!url) {
	      alert("URL을 입력해주세요.");
	      return;
	    }
	    
	    url = https://rpssurvey.hrcglobal.com/?qn=q21designv2_2&test=1&qnum=q100;
	    iframe.src = url;  // 항상 절대 URL로 세팅
	  }
	
	  button.addEventListener("click", loadPreview);
	  input.addEventListener("keydown", (e) => {
	    if (e.key === "Enter") loadPreview();
	  });
	</script>

  <section class="panel" aria-labelledby="code-title">
    <div class="panel-title" id="code-title">코드</div>

    <div class="tabs" role="tablist" aria-label="엔진 탭">
      <button class="tab" role="tab" aria-selected="true" aria-controls="qm-panel" id="tab-qm">Q-M</button>
      <button class="tab" role="tab" aria-selected="false" aria-controls="perl-panel" id="tab-perl">Perl</button>
    </div>

    <div class="codebar">
      <div class="left">
        <label for="engine" class="muted">엔진 옵션</label>
        <select id="engine" class="select" aria-label="엔진 옵션">
          <option value="default" selected>기본</option>
          <option value="legacy">레거시</option>
          <option value="experimental">Experimental</option>
        </select>
      </div>
      <div class="right">
        <button id="copyBtn" class="btn">코드 복사</button>
      </div>
    </div>

    <!-- Q-M 코드 -->
    <div id="qm-panel" role="tabpanel" aria-labelledby="tab-qm">
      <pre id="qm-code"><code># Q-M 예시 (엔진: 기본)
# 카테고리/검색 값은 상단 컨트롤을 통해 바인딩됩니다.

component &quot;single_select&quot; {
  label: &quot;가장 선호하는 항목을 선택하세요&quot;
  options: [&quot;A&quot;, &quot;B&quot;, &quot;C&quot;]
  required: true
}

logic {
  when answer(&quot;single_select&quot;) == &quot;C&quot; then show(&quot;follow_up&quot;)
}

component &quot;follow_up&quot; {
  label: &quot;선호 이유를 입력해주세요&quot;
  type: &quot;text&quot;
  rows: 3
}</code></pre>
    </div>

    <!-- Perl 코드 -->
    <div id="perl-panel" role="tabpanel" aria-labelledby="tab-perl" hidden>
      <pre id="perl-code"><code># Perl 예시 (엔진: 기본)
use strict;
use warnings;

my @options = ('A','B','C');
print &quot;가장 선호하는 항목을 선택하세요\n&quot;;
for my $i (0..$#options){ print ($i+1).&quot;. $options[$i]\n&quot;; }

# 응답 로직 (개념 예시)
my $ans = &lt;STDIN&gt;;
chomp $ans;
if ($options[$ans-1] eq 'C'){
  print &quot;선호 이유를 입력해주세요:\n&quot;;
  my $reason = &lt;STDIN&gt;;
  chomp $reason;
}</code></pre>
    </div>
  </section>
</main>

<footer>
  <div class="container">
    <p class="muted">※ 이 화면은 1차 배포 전 프론트 시안입니다. 스토리보드의 권한·옵션 구조(개발자: 뷰/코드, 엔진 옵션, 공통 검색·카테고리·뷰)를 그대로 반영했습니다. :contentReference[oaicite:1]{index=1}</p>
  </div>
</footer>

<script>
  // ====== 뷰 모드 전환 (PC / 모바일 / 모바일 가로)
  const modeBtns = document.querySelectorAll('.view-modes .chip');
  const iframe = document.getElementById('preview');
  function setMode(mode){
    modeBtns.forEach(b => b.setAttribute('aria-pressed', String(b.dataset.mode===mode)));
    iframe.className = 'device'; // reset
    if(mode==='mobile'){ iframe.classList.add('mobile'); }
    if(mode==='mobile-land'){ iframe.classList.add('mobile','landscape'); }
  }
  modeBtns.forEach(b => b.addEventListener('click', () => setMode(b.dataset.mode)));

  // ====== 미리보기 URL 로드
  document.getElementById('loadBtn').addEventListener('click', () => {
    const url = document.getElementById('previewUrl').value.trim();
    if(!url){ alert('URL을 입력하세요.'); return; }
    try{ 
      new URL(url); 
      iframe.src = url; 
      // 로딩 상태 표시
      iframe.style.opacity = '0.7';
      iframe.onload = () => {
        iframe.style.opacity = '1';
      };
      iframe.onerror = () => {
        alert('페이지를 불러오는데 실패했습니다. URL을 확인해주세요.');
        iframe.style.opacity = '1';
      };
    } catch(e){ alert('유효한 URL이 아닙니다.'); }
  });

  // ====== 탭 전환 (Q-M / Perl)
  const tabQM = document.getElementById('tab-qm');
  const tabPerl = document.getElementById('tab-perl');
  const panelQM = document.getElementById('qm-panel');
  const panelPerl = document.getElementById('perl-panel');
  function openTab(which){
    const isQM = which==='qm';
    tabQM.setAttribute('aria-selected', isQM);
    tabPerl.setAttribute('aria-selected', !isQM);
    panelQM.hidden = !isQM;
    panelPerl.hidden = isQM;
  }
  tabQM.addEventListener('click', () => openTab('qm'));
  tabPerl.addEventListener('click', () => openTab('perl'));

  // ====== 엔진 옵션에 따라 코드 블록 레이블 변경 (데모)
  const engineSel = document.getElementById('engine');
  const qmCode = document.getElementById('qm-code');
  const perlCode = document.getElementById('perl-code');
  const qmBase = qmCode.textContent;
  const perlBase = perlCode.textContent;
  engineSel.addEventListener('change', () => {
    const label = engineSel.value === 'legacy' ? '레거시'
                : engineSel.value === 'experimental' ? 'Experimental' : '기본';
    qmCode.textContent = qmBase.replace(/\(엔진: .*?\)/,'(엔진: '+label+')');
    perlCode.textContent = perlBase.replace(/\(엔진: .*?\)/,'(엔진: '+label+')');
  });

  // ====== 코드 복사
  document.getElementById('copyBtn').addEventListener('click', async () => {
    const active = panelPerl.hidden ? qmCode.textContent : perlCode.textContent;
    try{
      await navigator.clipboard.writeText(active);
      const btn = document.getElementById('copyBtn');
      const old = btn.textContent;
      btn.textContent = '복사됨!';
      setTimeout(()=>btn.textContent = old, 1200);
    }catch(e){ alert('복사에 실패했습니다: ' + e.message); }
  });

  // ====== 카테고리 드롭다운 처리
  const categorySelects = document.querySelectorAll('.filter-item select');
  const selectedValueSpan = document.querySelector('.selected-value');
  
  categorySelects.forEach(select => {
    select.addEventListener('change', function() {
      if (this.value === '') {
        return;
      }
      
      // 선택된 항목을 하나의 표시 영역에 표시 (카테고리 상관없이 1개만)
      const selectedOption = this.options[this.selectedIndex];
      if (selectedValueSpan) {
        selectedValueSpan.textContent = selectedOption.text;
      }
      
      // 선택 후 즉시 카테고리명으로 되돌리기 (모션 없이)
      this.selectedIndex = 0;
    });
    
    // 드롭다운 열릴 때 첫 번째 옵션(카테고리명)이 선택되지 않도록
    select.addEventListener('mousedown', function() {
      if (this.selectedIndex === 0) {
        this.selectedIndex = 1;
      }
    });
    
    // 드롭다운 닫힐 때 카테고리명이 표시되도록
    select.addEventListener('blur', function() {
      this.selectedIndex = 0;
    });
  });

  // 초기 상태
  setMode('pc');
</script>
</body>
</html>
